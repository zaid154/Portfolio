# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
# Preferred backend port. If it's busy the server automatically uses the next free
# port and prints the real one — so a collision never stops it from starting.
PORT=5000
# CORS allow-list (comma-separated). In dev any localhost origin is allowed anyway,
# so this only matters in production — set it to your deployed frontend URL(s).
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/portfolio
# Optional: force DNS resolvers if mongodb+srv SRV lookups fail on your machine.
# DNS_SERVERS=8.8.8.8,1.1.1.1

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── First admin (created by `npm run seed`) ───────────────────────────────────
ADMIN_NAME=Mohd Zaid
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ── Cloudinary (image uploads; uploads are disabled if these are blank) ────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=portfolio-cms

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Leave UNSET for local dev — the Vite dev server proxies /api to the backend.
# Set it ONLY in your production frontend host (Vercel), e.g.:
# VITE_API_URL=https://<your-render-service>.onrender.com/api
