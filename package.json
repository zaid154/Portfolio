{
  "name": "mohd-zaid-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "start": "npm start --prefix server",

    "seed": "npm run seed --prefix server",

    "build": "npm run build --prefix client",
    "preview": "npm run preview --prefix client",
    "lint": "npm run lint --prefix client",

    "install:all": "npm install && npm install --prefix client && npm install --prefix server"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}